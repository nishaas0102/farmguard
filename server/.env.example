# Option 1: Neon PostgreSQL (production) — set this and skip DB_HOST/DB_NAME/etc.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option 2: Local MySQL (development) — used when DATABASE_URL is not set
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=farmguard_db

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

PORT=5000
NODE_ENV=development

# Twilio credentials for WhatsApp + SMS notifications
# Sign up at https://www.twilio.com to get your credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+1234567890
